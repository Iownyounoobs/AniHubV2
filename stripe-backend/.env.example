# Stripe — get from Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=

# Stripe Webhook — get from Stripe Dashboard > Developers > Webhooks (after creating endpoint)
STRIPE_WEBHOOK_SECRET=

# Pricing in cents (e.g. 500 = $5.00, 4500 = $45.00)
STRIPE_MONTHLY_PRICE_CENTS=500
STRIPE_YEARLY_PRICE_CENTS=4500

# Firebase Admin — get from Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend URL — used for Stripe success/cancel redirects
FRONTEND_URL=http://localhost:3000

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000

# Server port
PORT=3002
